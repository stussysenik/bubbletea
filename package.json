{
  "name": "bubbletea-zig-automation",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:sync": "node scripts/update-docs.mjs",
    "docs:check": "node scripts/update-docs.mjs --check",
    "web:check": "node --check zig/web/app.js",
    "web:serve": "python3 -m http.server --directory zig/zig-out/web/showcase 4173",
    "openspec:status": "npx -y @fission-ai/openspec@latest status --change rewrite-bubbletea-in-zig",
    "openspec:validate": "npx -y @fission-ai/openspec@latest validate rewrite-bubbletea-in-zig --type change --strict --no-interactive",
    "ralph:loop": "bash scripts/ralph-loop.sh rewrite-bubbletea-in-zig",
    "ralph:watch": "WATCH_MODE=1 bash scripts/ralph-loop.sh rewrite-bubbletea-in-zig --watch",
    "release:status": "node scripts/release-status.mjs",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci"
  },
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/release-notes-generator": "14.1.0",
    "semantic-release": "24.2.8"
  },
  "overrides": {
    "lodash-es": "4.17.21"
  }
}
